@model  List<MessageViewModel>
@{
    Layout = "_AdminLayout"; 
    ViewData["Title"] = "Inbox Overview";

}


<div class="d-flex justify-content-between align-items-center mb-4 page-header">
    <div>
        <h1 class="fw-bold mb-1">Inbox Overview</h1>
        <p class="text-muted small mb-0">Manage and respond to inbound inquiries.</p>
    </div>
  
</div>


<div class="inbox-container">

    <form asp-action="Index" method="post">

    <div class="d-flex justify-content-between align-items-center mb-4">
         
            <div class="input-group search-box">
            <span class="input-group-text bg-white border-end-0 text-muted">
                <i class="fa-solid fa-magnifying-glass"></i>
            </span>
                <input type="text" name="search" class="form-control border-start-0 ps-0" placeholder="Search messages...">

                
              </div> 

              
            <button type="submit" class=" btn btn-info">search</button>
             
    </div>

    </form>

    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th >Sender</th>
                    <th >Contact</th>
                    <th>Message Excerpt</th>
                    <th>Message Date</th>
                    <th>Actions</th>
                   
                </tr>
            </thead>
            <tbody>
               @if (Model != null )
                {
                    foreach (var msg in Model)
                    {
                        

                        <tr>
                            <td>
                                <div class="d-flex align-items-center gap-3">
                                    
                                    <span class="fw-semibold text-dark">@msg.Name</span>
                                </div>
                            </td>
                            <td class="text-muted">@msg.Email</td>
                            <td>
                                <div class="msg-excerpt" title="@msg.Message">
                                    @msg.Message
                                </div>
                            </td>
                            <td class="text-muted small">@msg.TimeAgo</td>

                            <td class="text-end">
                                <div class="d-flex align-items-center justify-content-end gap-3">

                                    <a asp-action="ToggleReadStatus" asp-route-id="@msg.Id"
                                       class="btn btn-sm border @(msg.IsRead == true ?   "bg-primary-subtle text-primary border-primary-subtle":"btn-light text-secondary border-secondary-subtle")"
                                       >
                                       <span>@(msg.IsRead == true ? "Mark as read" : "Mark as un Read")</span>
                                        <i class="@(msg.IsRead == true ? "fa-solid fa-envelope text-primary" : "fa-regular fa-envelope-open text-secondary")"></i>

                                        
                                    </a>


                                    <a asp-action="Delete" asp-route-id="@msg.Id" class="btn btn-sm btn-light text-danger border"
                                       onclick="return confirm('Are you sure you want to delete this service?');">
                                        <i class="fa-regular fa-trash-can"></i>
                                    </a>

                                </div>
                            </td>
                        </tr>

                      
                    }
                }
                else
                {
                    <tr>
                        <td colspan="4" class="text-center text-muted py-5">
                            <i class="fa-solid fa-envelope-open fs-2 mb-3 d-block text-muted"></i>
                            No messages found in your inbox.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

  

</div>