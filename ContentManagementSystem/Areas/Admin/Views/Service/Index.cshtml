@model IEnumerable<ServiceViewModel>

@{
    ViewData["Title"] = "Services";
}

<div class="d-flex justify-content-between align-items-end mb-4">
    <div>
        <h2 class="h3 fw-bold text-dark mb-1">Services</h2>
        <p class="text-muted small mb-0">Manage and organize your offered services.</p>
    </div>
    <div class="d-flex gap-2">
       
        <a asp-action="Create" class="btn text-white fw-medium border-0 d-flex align-items-center gap-2"
           style="background-color: #4f46e5; font-size: 0.875rem;">
            <i class="fa-solid fa-plus"></i> Add New Service
        </a>
    </div>
</div>

<div class="card shadow-sm border rounded-3 bg-white overflow-hidden">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead style="background-color: #f8fafc;">
                <tr class="text-secondary small" style="letter-spacing: 0.5px;">
                    <th class="ps-4 py-3 fw-semibold border-bottom-0 text-uppercase" style="width: 80px;">Icon</th>
                    <th class="py-3 fw-semibold border-bottom-0 text-uppercase">Service Name</th>
                    <th class="py-3 fw-semibold border-bottom-0 text-uppercase">Description</th>
                    <th class="pe-4 py-3 fw-semibold border-bottom-0 text-uppercase text-end">Actions</th>
                </tr>
            </thead>
            <tbody class="border-top-0">

                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4 py-3">
                                <div class="d-flex align-items-center justify-content-center rounded"
                                     style="width: 40px; height: 40px; background-color: #e0e7ff; color: #4f46e5;">
                                    <i class="fa-solid @item.Icon fs-5"></i>
                                </div>
                            </td>

                            <td class="py-3">
                                <span class="fw-medium text-dark">@item.Title</span>
                            </td>

                            <td class="py-3 text-muted small" style="max-width: 300px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                                @item.Description
                            </td>

                       

                            <td class="pe-4 py-3 text-end">
                                <a asp-action="update" asp-route-id="@item.Id" class="btn btn-sm btn-light text-secondary me-1 border">
                                    <i class="fa-regular fa-pen-to-square"></i>
                                </a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-light text-danger border" 
                                   onclick="return confirm('Are you sure you want to delete this service?');">
                                    <i class="fa-regular fa-trash-can"></i>
                                </a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" class="text-center py-5 text-muted">
                            <i class="fa-solid fa-folder-open fs-2 mb-3 text-light"></i>
                            <p class="mb-0">No services added yet. Click "Add New Service" to get started.</p>
                        </td>
                    </tr>
                }

            </tbody>
        </table>
    </div>

   
</div>