@model HeroViewModel
@{
    ViewData["Title"] = "Hero Section Editor";
}

<div class="card shadow-sm border rounded-3 bg-white">
    <div class="card-header bg-white border-bottom p-4">
        <h2 class="h5 fw-bold text-dark mb-1">Hero Section Editor</h2>
        <p class="text-muted small mb-0">Manage the primary content visible at the top of the landing page.</p>
    </div>

    <div class="card-body p-4">
        <form asp-controller="Hero" asp-action="AddHero" method="post" enctype="multipart/form-data">

            @* <input  type="hidden" asp-for="Id"/> *@
            <input type="hidden" asp-for="ImageUrl" />

            <div class="mb-5">
                <h6 class="text-uppercase fw-bold text-custom-indigo mb-3" style="font-size: 0.75rem; letter-spacing: 0.05em;">
                    Typography & Content
                </h6>

                <div class="mb-3">
                    <label asp-for="Title" class="form-label fw-semibold small text-secondary">Main Title</label>
                    <input type="text" asp-for="Title" class="form-control form-control-md rounded-2" placeholder="Enter main title..." />
                </div>

                <div class="mb-3">
                    <label asp-for="Description" class="form-label fw-semibold small text-secondary">Subtitle / Description</label>
                    <textarea asp-for="Description" class="form-control form-control-md rounded-2" rows="4" placeholder="Enter subtitle or description..."></textarea>
                </div>
            </div>

          

            <div class="mb-4">
                <h6 class="text-uppercase fw-bold text-custom-indigo mb-3" style="font-size: 0.75rem; letter-spacing: 0.05em;">
                    Background Media
                </h6>

                <label class="form-label fw-semibold small text-secondary mb-2">Hero Image</label>

                <div class="mb-3 rounded-3 overflow-hidden border">
                    @if (!string.IsNullOrEmpty(Model?.ImageUrl))
                    {
                        <img src="~/files/images/@Model.ImageUrl" alt="Hero Background" class="w-100 d-block" style="height: 200px; object-fit: cover;" />
                    }
                    else
                    {
                        <div class="bg-light d-flex align-items-center justify-content-center text-muted" style="height: 200px;">
                            <span class="small">No image uploaded yet</span>
                        </div>
                    }
                </div>

                <div class="position-relative border border-2 border-dashed rounded-3 p-4 text-center bg-light-subtle hover-bg-light transition"
                     style="border-style: dashed !important; border-color: #cbd5e1 !important;">
                    <input type="file" asp-for="ImageFile" class="position-absolute top-0 start-0 w-100 h-100 opacity-0 custom-file-input" style="cursor: pointer;" />

                    <div class="py-2">
                        <div class="text-secondary mb-2">
                            <i class="fa-solid fa-cloud-arrow-up fs-3 text-muted"></i>
                        </div>
                        <p class="mb-1 small text-dark">
                            <span class="text-custom-indigo fw-semibold">Click to upload</span> or drag and drop
                        </p>
                        <span class="text-muted d-block" style="font-size: 0.75rem;">SVG, PNG, JPG or WEBP (max. 5MB)</span>
                    </div>
                </div>
            </div>

            <div class="d-flex justify-content-end gap-2 pt-3 border-top">
                <a href="#" class="btn btn-light border px-4 fw-medium text-secondary" style="font-size: 0.875rem;">Cancel</a>
                <button type="submit" class="btn bg-custom-indigo text-white px-4 fw-medium border-0" style="font-size: 0.875rem;">
                    <i class="fa-regular fa-floppy-disk me-1"></i> Save Changes
                </button>
            </div>

        </form>
    </div>
</div>