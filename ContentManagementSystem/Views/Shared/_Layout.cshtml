

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Modern CMS</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ContentManagementSystem.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css" />

    <style>
        :root {
        --primary-color: #4f46e5;
        --primary-light: #e0e7ff;
        --text-dark: #0f172a;
        --text-muted: #64748b;
        }

        body {
        font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
        color: var(--text-dark);
        background-color: #ffffff;
        }
        /* Navbar */
        .navbar {
        border-bottom: 1px solid #f1f5f9;
        }

        .nav-link {
        font-weight: 500;
        color: var(--text-dark);
        }

        .nav-link:hover, .nav-link.active {
        color: var(--primary-color);
        }

        .btn-primary-custom {
        background-color: var(--primary-color);
        color: white;
        transition: 0.3s;
        }

        .btn-primary-custom:hover {
        background-color: #4338ca;
        color: white;
        transform: translateY(-2px);
        }
        /* Footer */
        .footer {
        background-color: #f1f5f9;
        border-top: 1px solid #e2e8f0;
        }
    </style>

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

    <nav class="navbar navbar-expand-lg bg-white sticky-top py-3">
        <div class="container">
            <a class="navbar-brand fw-bold text-primary-custom d-flex align-items-center gap-2" href="/">
                <i class="fa-solid fa-cubes fs-4"></i> CMS Admin
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav mx-auto gap-3">
                    <li class="nav-item"><a class="nav-link" href="/">Home</a></li>
                    <li class="nav-item"><a class="nav-link" href="#about">About</a></li>
                    <li class="nav-item"><a class="nav-link" href="#services">Services</a></li>
                    <li class="nav-item"><a class="nav-link" href="#contact">Contact</a></li>
                </ul>
               
            </div>
        </div>
    </nav>

    <main>
        @RenderBody()
    </main>


    <div style="height: 200px; width: 100%; clear: both;"></div>

    <footer class="footer mt-5 pt-5 pb-4">
        <div class="container">
            <div class="row g-4">
                <div class="col-lg-4">
                    <h5 class="fw-bold text-dark mb-3">CMS Admin</h5>
                    <p class="text-muted small pe-4">Empowering modern teams with scalable, elegant, and robust digital solutions.</p>
                </div>
                <div class="col-lg-2 offset-lg-2 col-md-4">
                    <h6 class="fw-bold text-dark mb-3">Company</h6>
                    <ul class="list-unstyled text-muted small lh-lg">
                        <li><a href="#" class="text-decoration-none text-muted">About Us</a></li>
                        <li><a href="#" class="text-decoration-none text-muted">Services</a></li>
                    </ul>
                </div>
                <div class="col-lg-2 col-md-4">
                    <h6 class="fw-bold text-dark mb-3">Legal</h6>
                    <ul class="list-unstyled text-muted small lh-lg">
                        <li><a href="#" class="text-decoration-none text-muted">Privacy Policy</a></li>
                        <li><a href="#" class="text-decoration-none text-muted">Terms of Service</a></li>
                    </ul>
                </div>
            </div>
            <div class="border-top mt-4 pt-4 text-muted small text-center">
                © 2024 CMS Project. All rights reserved.
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
